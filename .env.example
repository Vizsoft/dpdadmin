# ─── Supabase (required) ───────────────────────────────────────────
# ENV SPLIT (minimal):
# - Local / test / preview: use TEST Supabase project keys
# - Vercel production: use PROD Supabase project keys
# Only Supabase keys + R2_BUCKET_NAME should differ by environment.
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Fallback if publishable key is empty:
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never use NEXT_PUBLIC_ prefix
# Dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=

# ─── App URL (required for auth redirects) ───────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── MapTiler (Zones map — optional; falls back to OpenStreetMap) ─
# https://docs.maptiler.com/ — create key at cloud.maptiler.com
NEXT_PUBLIC_MAPTILER_API_KEY=
NEXT_PUBLIC_MAPTILER_MAP_ID=streets-v2

# ─── Google Maps (Restaurant pin + place search — optional) ────────
# Enable Maps JavaScript API + Places API in Google Cloud Console.
# Restrict key to HTTP referrers (localhost + production domain).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ─── Cloudflare R2 (driver docs + partner logos — server only) ─────
# Keep account credentials shared; only bucket name changes by env:
# - test/local/preview: dpd-private-dev
# - production: dpd-private
# Set in Vercel production; never exposed in the admin UI.
# Dashboard → R2 Overview → Manage API tokens → Object Read & Write (S3 keys)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=dpd-private
# Optional; defaults to https://{R2_ACCOUNT_ID}.r2.cloudflarestorage.com
R2_S3_ENDPOINT=
# Account API token (cfat_*) with Analytics:Read for R2 stats dashboard
CLOUDFLARE_API_TOKEN=

# Driver app CORS origins (comma-separated) for /api/driver-uploads/*
DRIVER_APP_ORIGINS=http://localhost:8081,exp://localhost:8081

# Protects GET /api/cron/storage-uploads-cleanup (Vercel Cron)
CRON_SECRET=

# ─── Firebase (notifications + telemetry; server only) ─────────────
# Project: Musallam Delivery (musallam-delivery-kw)
# Supports FCM delivery + Analytics/Crashlytics/Performance/Remote Config hooks.
# Recommended: provide full service account JSON in FIREBASE_SERVICE_ACCOUNT_JSON.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=musallam-delivery-kw
FIREBASE_CLIENT_EMAIL=
# Multiline private key supported with escaped newlines (\n)
FIREBASE_PRIVATE_KEY=
# Public client config (safe for mobile; also served via /api/driver-app/firebase-config)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=musallam-delivery-kw
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=942102607123
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=musallam-delivery-kw.firebasestorage.app
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=musallam-delivery-kw.firebaseapp.com
NEXT_PUBLIC_FIREBASE_APP_ID=
FIREBASE_APP_ID_ANDROID=1:942102607123:android:2b709642cb7ab7a48096e6
FIREBASE_APP_ID_IOS=1:942102607123:ios:442ef4381a6480f48096e6
FIREBASE_APP_ID_WEB=1:942102607123:web:6522f617aca8ff2f8096e6
# Feature toggles
FIREBASE_ANALYTICS_ENABLED=true
FIREBASE_CRASHLYTICS_ENABLED=true
FIREBASE_PERFORMANCE_ENABLED=true
FIREBASE_REMOTE_CONFIG_ENABLED=true
# Notification operations defaults
NOTIFICATION_APPROVAL_REQUIRED_CATEGORIES=high,broadcast,emergency
NOTIFICATION_SEND_RATE_PER_MINUTE=600
NOTIFICATION_BATCH_SIZE=500

# ─── One-time admin bootstrap (local only, run: npm run bootstrap:admin) ─
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=change-me-min-8-chars
