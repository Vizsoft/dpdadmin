# ─── Supabase (required) ───────────────────────────────────────────
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Fallback if publishable key is empty:
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never use NEXT_PUBLIC_ prefix
# Dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=

# ─── App URL (required for auth redirects) ───────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── MapTiler (Zones map — optional; falls back to OpenStreetMap) ─
# https://docs.maptiler.com/ — create key at cloud.maptiler.com
NEXT_PUBLIC_MAPTILER_API_KEY=
NEXT_PUBLIC_MAPTILER_MAP_ID=streets-v2

# ─── Google Maps (Restaurant pin + place search — optional) ────────
# Enable Maps JavaScript API + Places API in Google Cloud Console.
# Restrict key to HTTP referrers (localhost + production domain).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ─── Cloudflare R2 (driver docs + partner logos — server only) ─────
# Dashboard → R2 → bucket + API token (Object Read & Write)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=dpd-private
# Optional; defaults to https://{R2_ACCOUNT_ID}.r2.cloudflarestorage.com
R2_S3_ENDPOINT=

# ─── One-time admin bootstrap (local only, run: npm run bootstrap:admin) ─
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=change-me-min-8-chars
