    "env:push-vercel": "node scripts/push-vercel-env.mjs",
    "db:types": "supabase gen types typescript --project-id ytfmsgckjatiserpgdbz 2>/dev/null > src/types/database.ts && printf '\\nexport type AppRole = Database[\"public\"][\"Enums\"][\"app_role\"];\\nexport type AdminApprovalStatus = Database[\"public\"][\"Enums\"][\"admin_approval_status\"];\\nexport type Profile = Database[\"public\"][\"Tables\"][\"profiles\"][\"Row\"];\\n' >> src/types/database.ts"
  },
